# Copy this to .env.local for local dev, .env.production for production builds.
# VITE_ prefix required for Vite to expose variables to browser code.

# Backend API base URL (no trailing slash)
VITE_API_BASE=http://localhost:8000

# WebSocket base URL — leave blank to auto-derive from VITE_API_BASE
# VITE_WS_BASE=ws://localhost:8000

# Production example:
# VITE_API_BASE=https://api.aegibit.com
# VITE_WS_BASE=wss://api.aegibit.com
